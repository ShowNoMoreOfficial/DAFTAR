{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/relay-executor",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/performance-sync",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/learning-loop",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/overdue-check",
      "schedule": "0 */4 * * *"
    }
  ]
}
