# DAFTAR Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit .env to git — only commit this template

# ═══════════════════════════════════════════
# DATABASE (NeonDB)
# ═══════════════════════════════════════════
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ═══════════════════════════════════════════
# AUTH (NextAuth v5)
# ═══════════════════════════════════════════
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://your-app.vercel.app

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID — https://portal.azure.com → App Registrations (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Email Magic Link Login — cPanel email settings (Set Up Mail Client in cPanel)
EMAIL_SERVER_HOST=mail.shownomore.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=noreply@shownomore.com
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=Daftar <noreply@shownomore.com>

# ═══════════════════════════════════════════
# AI APIS
# ═══════════════════════════════════════════
# Google AI Studio — https://aistudio.google.com → Get API Key
GEMINI_API_KEY=

# Anthropic — https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ElevenLabs — https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=

# ═══════════════════════════════════════════
# BACKGROUND JOBS (Inngest)
# ═══════════════════════════════════════════
# Inngest — https://inngest.com → Your App → Manage → Keys
# Leave empty for local dev mode
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ═══════════════════════════════════════════
# META (Facebook + Instagram) — https://developers.facebook.com
# ═══════════════════════════════════════════
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://your-app.vercel.app/api/auth/callback/meta

# ═══════════════════════════════════════════
# EXTERNAL SERVICES
# ═══════════════════════════════════════════
KHABRI_API_KEY=
