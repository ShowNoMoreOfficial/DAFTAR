# DAFTAR Environment Variables Template
# Copy this to .env.local and fill in your values
# NEVER commit .env or .env.local to git — only commit this template

# ═══════════════════════════════════════════
# DATABASE (NeonDB)
# ═══════════════════════════════════════════
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ═══════════════════════════════════════════
# AUTH (NextAuth v5)
# ═══════════════════════════════════════════
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="https://daftar-one.vercel.app"

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# Microsoft Entra ID — https://portal.azure.com → App Registrations (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ═══════════════════════════════════════════
# EMAIL (Magic Link Login)
# ═══════════════════════════════════════════
# cPanel email settings (Set Up Mail Client in cPanel)
EMAIL_SERVER_HOST="mail.shownomore.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="noreply@shownomore.com"
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="Daftar <noreply@shownomore.com>"

# ═══════════════════════════════════════════
# AI APIs
# ═══════════════════════════════════════════
# Google AI Studio — https://aistudio.google.com → Get API Key
GEMINI_API_KEY="your-gemini-api-key"

# Anthropic — https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ElevenLabs — https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY="your-elevenlabs-key"

# ═══════════════════════════════════════════
# BACKGROUND JOBS (Inngest)
# ═══════════════════════════════════════════
# Inngest — https://inngest.com → Your App → Manage → Keys
# Leave empty for local dev mode
INNGEST_EVENT_KEY="your-inngest-event-key"
INNGEST_SIGNING_KEY="your-inngest-signing-key"

# Cron job protection
CRON_SECRET="generate-random-string"

# ═══════════════════════════════════════════
# RELAY — Social Platform OAuth (Publishing)
# ═══════════════════════════════════════════

# YouTube (via Google OAuth 2.0) — https://console.cloud.google.com → Credentials
# Uses same Google project as auth. Enable YouTube Data API v3.
GOOGLE_CLIENT_ID="same-as-AUTH_GOOGLE_ID"
GOOGLE_CLIENT_SECRET="same-as-AUTH_GOOGLE_SECRET"
GOOGLE_REDIRECT_URI="https://daftar-one.vercel.app/api/relay/oauth/youtube/callback"

# Twitter / X (OAuth 2.0 PKCE) — https://developer.twitter.com → Projects → Keys
TWITTER_CLIENT_ID=""
TWITTER_CLIENT_SECRET=""
TWITTER_REDIRECT_URI="https://daftar-one.vercel.app/api/relay/oauth/x/callback"

# Meta (Facebook + Instagram) — https://developers.facebook.com → My Apps
# Enable products: Instagram Graph API, Pages API
META_APP_ID=""
META_APP_SECRET=""
META_IG_REDIRECT_URI="https://daftar-one.vercel.app/api/relay/oauth/instagram/callback"
META_FB_REDIRECT_URI="https://daftar-one.vercel.app/api/relay/oauth/facebook/callback"

# LinkedIn — https://developer.linkedin.com → My Apps → Auth
# Enable products: "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn"
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
LINKEDIN_REDIRECT_URI="https://daftar-one.vercel.app/api/relay/oauth/linkedin/callback"

# ═══════════════════════════════════════════
# GOOGLE ADS API
# ═══════════════════════════════════════════
# Developer token — https://ads.google.com → Tools & Settings → API Center
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ═══════════════════════════════════════════
# EXTERNAL SERVICES
# ═══════════════════════════════════════════
KHABRI_API_KEY="your-khabri-api-key"
