generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  HEAD_HR
  DEPT_HEAD
  MEMBER
  CLIENT
  FINANCE
  CONTRACTOR
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum DepartmentType {
  MEDIA
  TECH
  MARKETING
  PRODUCTION
  PPC
  PHOTOGRAPHY
  HR_OPS
  FINANCE_DEPT
  CUSTOM
}

// ─── Invitations ────────────────────────────────────────

model Invite {
  id           String       @id @default(cuid())
  email        String
  role         Role         @default(MEMBER)
  departmentId String?
  department   Department?  @relation("DeptInvites", fields: [departmentId], references: [id])
  status       InviteStatus @default(PENDING)
  token        String       @unique @default(cuid())
  invitedById  String
  expiresAt    DateTime
  acceptedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([email])
  @@index([token])
  @@map("invites")
}

// ─── Core Models ─────────────────────────────────────────

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  name                String
  avatar              String?
  role                Role                @default(MEMBER)
  isActive            Boolean             @default(false)
  primaryDepartment   Department?         @relation("PrimaryDept", fields: [primaryDeptId], references: [id])
  primaryDeptId       String?
  departments         DepartmentMember[]
  brandAccess         UserBrandAccess[]
  permissionOverrides UserPermission[]
  projectTags         ProjectMember[]
  sidebarPreference   SidebarPreference?
  client              Client?
  accounts            Account[]
  sessions            Session[]
  // PMS relations
  createdTasks        Task[]              @relation("TaskCreator")
  assignedTasks       Task[]              @relation("TaskAssignee")
  taskComments        TaskComment[]       @relation("CommentAuthor")
  taskActivities      TaskActivity[]      @relation("ActivityActor")
  credibilityScore    CredibilityScore?
  // HOCCR relations
  createdReports      Report[]            @relation("ReportCreator")
  // Notifications
  notifications       Notification[]
  // Gamification
  achievements        UserAchievement[]
  streak              UserStreak?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Department ──────────────────────────────────────────

model Department {
  id           String             @id @default(cuid())
  name         String             @unique
  type         DepartmentType
  description  String?
  config       Json?
  headId       String?
  members      DepartmentMember[]
  primaryUsers User[]             @relation("PrimaryDept")
  projects     Project[]
  tasks        Task[]             @relation("DeptTasks")
  positions    HiringPosition[]   @relation("DeptPositions")
  reports      Report[]           @relation("DeptReports")
  workflows    WorkflowTemplate[]
  expenses     Expense[]          @relation("DeptExpenses")
  invites      Invite[]           @relation("DeptInvites")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@map("departments")
}

model DepartmentMember {
  id           String     @id @default(cuid())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId String
  isPrimary    Boolean    @default(false)
  joinedAt     DateTime   @default(now())

  @@unique([userId, departmentId])
  @@map("department_members")
}

// ─── Client & Brand ──────────────────────────────────────

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  company   String?
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])
  brands    Brand[]
  invoices  Invoice[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

model Brand {
  id         String            @id @default(cuid())
  name       String
  slug       String            @unique
  client     Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId   String
  config     Json?
  platforms  BrandPlatform[]
  userAccess UserBrandAccess[]
  tasks      Task[]
  invoices   Invoice[]
  posts               ContentPost[]
  platformConnections PlatformConnection[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@map("brands")
}

model UserBrandAccess {
  id      String  @id @default(cuid())
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  brand   Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId String
  role    String?

  @@unique([userId, brandId])
  @@map("user_brand_access")
}

model BrandPlatform {
  id       String  @id @default(cuid())
  brand    Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId  String
  platform String
  config   Json?
  isActive Boolean @default(true)

  @@unique([brandId, platform])
  @@map("brand_platforms")
}

// ─── Projects ────────────────────────────────────────────

model Project {
  id          String          @id @default(cuid())
  name        String
  description String?
  department  Department      @relation(fields: [deptId], references: [id])
  deptId      String
  members     ProjectMember[]
  tasks       Task[]
  status      String          @default("active")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("projects")
}

model ProjectMember {
  id        String  @id @default(cuid())
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      String?

  @@unique([projectId, userId])
  @@map("project_members")
}

// ─── Permissions ─────────────────────────────────────────

model UserPermission {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  permission String
  granted    Boolean  @default(true)
  grantedBy  String
  createdAt  DateTime @default(now())

  @@map("user_permissions")
}

// ─── Sidebar ─────────────────────────────────────────────

model SidebarPreference {
  id        String @id @default(cuid())
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String @unique
  pinned    Json   @default("[]")
  collapsed Json   @default("[]")
  order     Json   @default("[]")

  @@map("sidebar_preferences")
}

// ─── Module Registry ─────────────────────────────────────

model Module {
  id          String  @id @default(cuid())
  name        String  @unique
  displayName String
  description String?
  icon        String?
  baseUrl     String
  isActive    Boolean @default(true)
  config      Json?
  order       Int     @default(0)

  @@map("modules")
}

// ─── PMS: Tasks ─────────────────────────────────────────

enum TaskStatus {
  CREATED
  ASSIGNED
  IN_PROGRESS
  REVIEW
  APPROVED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id            String       @id @default(cuid())
  title         String
  description   String?      @db.Text
  status        TaskStatus   @default(CREATED)
  priority      TaskPriority @default(MEDIUM)
  difficultyWeight Int       @default(1)

  // Relations
  creator       User         @relation("TaskCreator", fields: [creatorId], references: [id])
  creatorId     String
  assignee      User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assigneeId    String?
  department    Department?  @relation("DeptTasks", fields: [departmentId], references: [id])
  departmentId  String?
  brand         Brand?       @relation(fields: [brandId], references: [id])
  brandId       String?
  project       Project?     @relation(fields: [projectId], references: [id])
  projectId     String?

  // Dates
  dueDate       DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Sub-relations
  comments      TaskComment[]
  activities    TaskActivity[]
  tags          TaskTag[]

  @@index([assigneeId, status])
  @@index([departmentId, status])
  @@index([status])
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  author    User     @relation("CommentAuthor", fields: [authorId], references: [id])
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("task_comments")
}

model TaskActivity {
  id        String   @id @default(cuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  actor     User     @relation("ActivityActor", fields: [actorId], references: [id])
  actorId   String
  action    String
  field     String?
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  @@map("task_activities")
}

model TaskTag {
  id     String @id @default(cuid())
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String
  name   String

  @@unique([taskId, name])
  @@map("task_tags")
}

// ─── PMS: Credibility Scoring ───────────────────────────

model CredibilityScore {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String   @unique
  reliability    Float    @default(50)
  quality        Float    @default(50)
  consistency    Float    @default(50)
  overallScore   Float    @default(50)
  tasksCompleted Int      @default(0)
  tasksOnTime    Int      @default(0)
  tasksLate      Int      @default(0)
  updatedAt      DateTime @updatedAt

  @@map("credibility_scores")
}

// ─── HOCCR: Hiring Pipeline ─────────────────────────────

enum CandidateStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

model HiringPosition {
  id           String      @id @default(cuid())
  title        String
  department   Department  @relation("DeptPositions", fields: [departmentId], references: [id])
  departmentId String
  description  String?     @db.Text
  requirements Json?
  isOpen       Boolean     @default(true)
  candidates   HiringCandidate[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("hiring_positions")
}

model HiringCandidate {
  id           String          @id @default(cuid())
  name         String
  email        String
  phone        String?
  resumeUrl    String?
  status       CandidateStatus @default(APPLIED)
  position     HiringPosition  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  positionId   String
  notes        String?         @db.Text
  rating       Int?
  interviewDate DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@map("hiring_candidates")
}

// ─── HOCCR: Reports ─────────────────────────────────────

enum ReportType {
  DEPARTMENT_PERFORMANCE
  TEAM_WORKLOAD
  TASK_COMPLETION
  HIRING_PIPELINE
  CUSTOM
}

model Report {
  id           String     @id @default(cuid())
  title        String
  type         ReportType
  description  String?
  config       Json?
  generatedData Json?
  createdBy    User       @relation("ReportCreator", fields: [createdById], references: [id])
  createdById  String
  department   Department? @relation("DeptReports", fields: [departmentId], references: [id])
  departmentId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("reports")
}

// ─── HOCCR: Culture & Sentiment ─────────────────────────

enum SentimentLevel {
  VERY_NEGATIVE
  NEGATIVE
  NEUTRAL
  POSITIVE
  VERY_POSITIVE
}

model SentimentEntry {
  id           String         @id @default(cuid())
  userId       String
  departmentId String?
  sentiment    SentimentLevel @default(NEUTRAL)
  score        Float          @default(3.0) // 1-5 scale
  source       String         @default("manual") // manual, pulse, gi_detected
  notes        String?        @db.Text
  isAnonymous  Boolean        @default(false)
  createdAt    DateTime       @default(now())

  @@index([userId, createdAt])
  @@index([departmentId, createdAt])
  @@map("sentiment_entries")
}

model Recognition {
  id           String   @id @default(cuid())
  fromUserId   String
  toUserId     String
  category     String   // kudos, teamwork, innovation, quality, leadership
  message      String   @db.Text
  isPublic     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([toUserId, createdAt])
  @@index([fromUserId])
  @@map("recognitions")
}

model EngagementMetric {
  id           String   @id @default(cuid())
  userId       String
  departmentId String?
  period       String   // "2026-W10", "2026-03"
  taskCompletionRate Float @default(0)
  avgResponseTime    Float @default(0) // hours
  collaborationScore Float @default(0) // 0-100
  activeDays         Int   @default(0)
  recognitionsGiven  Int   @default(0)
  recognitionsReceived Int @default(0)
  overallScore       Float @default(0) // 0-100
  computedAt         DateTime @default(now())

  @@unique([userId, period])
  @@index([departmentId, period])
  @@map("engagement_metrics")
}

// ─── HOCCR: Operations ──────────────────────────────────

model Bottleneck {
  id           String   @id @default(cuid())
  type         String   // task_blocked, approval_delayed, capacity_exceeded, dependency_waiting
  severity     String   @default("medium") // low, medium, high, critical
  title        String
  description  String?  @db.Text
  departmentId String?
  taskId       String?
  blockedById  String?  // user causing the block
  affectedIds  Json?    // array of affected user/task ids
  status       String   @default("active") // active, acknowledged, resolved
  detectedAt   DateTime @default(now())
  resolvedAt   DateTime?

  @@index([status, severity])
  @@index([departmentId])
  @@map("bottlenecks")
}

model CapacitySnapshot {
  id           String   @id @default(cuid())
  userId       String
  departmentId String?
  period       String   // "2026-W10"
  totalCapacity Int     @default(40) // hours/week
  allocatedHours Float  @default(0)
  activeTaskCount Int   @default(0)
  totalWeight    Float  @default(0)
  utilizationPct Float  @default(0) // 0-100
  computedAt    DateTime @default(now())

  @@unique([userId, period])
  @@index([departmentId, period])
  @@map("capacity_snapshots")
}

// ─── HOCCR: Cross-Department Dependencies ───────────────

model CrossDeptDependency {
  id              String   @id @default(cuid())
  fromDeptId      String
  toDeptId        String
  taskId          String?
  description     String
  status          String   @default("waiting") // waiting, acknowledged, resolved, escalated
  priority        String   @default("medium") // low, medium, high, critical
  createdById     String
  acknowledgedById String?
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([fromDeptId, status])
  @@index([toDeptId, status])
  @@map("cross_dept_dependencies")
}

// ─── Notifications ──────────────────────────────────────

enum NotificationType {
  TASK_ASSIGNED
  TASK_STATUS_CHANGED
  TASK_COMMENT
  TASK_OVERDUE
  APPROVAL_PENDING
  APPROVAL_COMPLETED
  DELIVERABLE_READY
  GI_SUGGESTION
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  // JSON map of NotificationType -> {enabled: boolean, channels: ["in_app", "email"]}
  preferences     Json     @default("{}")
  quietHoursStart String?  // "22:00"
  quietHoursEnd   String?  // "08:00"
  updatedAt       DateTime @updatedAt

  @@map("notification_preferences")
}

// ─── Finance ────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum ExpenseCategory {
  SALARY
  SOFTWARE
  EQUIPMENT
  TRAVEL
  MARKETING
  PRODUCTION
  OFFICE
  MISCELLANEOUS
}

model Invoice {
  id          String        @id @default(cuid())
  number      String        @unique
  brand       Brand?        @relation(fields: [brandId], references: [id])
  brandId     String?
  client      Client?       @relation(fields: [clientId], references: [id])
  clientId    String?
  status      InvoiceStatus @default(DRAFT)
  amount      Float
  tax         Float         @default(0)
  totalAmount Float
  dueDate     DateTime
  paidAt      DateTime?
  description String?
  items       Json?
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([clientId])
  @@map("invoices")
}

model Expense {
  id           String          @id @default(cuid())
  title        String
  amount       Float
  category     ExpenseCategory
  department   Department?     @relation("DeptExpenses", fields: [departmentId], references: [id])
  departmentId String?
  description  String?
  receiptUrl   String?
  approvedBy   String?
  createdById  String
  date         DateTime        @default(now())
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([category])
  @@index([departmentId])
  @@map("expenses")
}

// ─── Configuration-over-Code ──────────────────────────────

model WorkflowTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  department  Department? @relation(fields: [departmentId], references: [id])
  departmentId String?
  stages      Json     // Array of stage definitions [{name, order, participants, approvalGate, autoGenRules}]
  triggers    Json?    // What events start this workflow
  escalation  Json?    // Escalation rules
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("workflow_templates")
}

model PlatformConfig {
  id              String  @id @default(cuid())
  platform        String  @unique  // youtube, x, instagram, linkedin, facebook
  displayName     String
  deliverableTypes Json   // [{type, formatSpecs, dimensions}]
  postingRules    Json?   // frequency limits, hashtag rules, etc
  analyticsMetrics Json?  // metrics tracked per platform
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("platform_configs")
}

model RoleConfig {
  id              String  @id @default(cuid())
  role            Role    @unique
  dashboardViews  Json    // accessible screens
  notifications   Json?   // event triggers for alerts
  reportAccess    Json?   // visible dashboards
  giConversation  Json?   // GI topic boundaries
  updatedAt       DateTime @updatedAt

  @@map("role_configs")
}

// ─── Gamification ──────────────────────────────────────

model Achievement {
  id          String   @id @default(cuid())
  key         String   @unique // e.g., "first_task", "streak_7", "quality_master"
  name        String
  description String
  icon        String   // emoji or icon name
  category    String   // milestone, streak, quality, speed, collaboration, special
  threshold   Int      @default(1) // e.g., complete 10 tasks, 7-day streak
  points      Int      @default(10)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  unlocks     UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  achievementId String
  unlockedAt    DateTime    @default(now())
  notified      Boolean     @default(false)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model UserStreak {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String   @unique
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastActivityAt DateTime @default(now())
  totalXp        Int      @default(0)
  level          Int      @default(1)
  updatedAt      DateTime @updatedAt

  @@map("user_streaks")
}

model MicroChallenge {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String   // speed, quality, volume, collaboration
  metric      String   // e.g., "fastest_task_completion", "most_first_pass_approvals"
  targetValue Float?   // optional target to beat
  currentRecord Json?  // {userId, value, recordedAt}
  departmentId String? // null = org-wide
  startsAt    DateTime
  endsAt      DateTime
  bonusPoints Int      @default(25)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  entries     ChallengeEntry[]

  @@index([isActive, endsAt])
  @@map("micro_challenges")
}

model ChallengeEntry {
  id           String         @id @default(cuid())
  challenge    MicroChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  challengeId  String
  userId       String
  value        Float
  taskId       String?
  submittedAt  DateTime       @default(now())

  @@unique([challengeId, userId])
  @@map("challenge_entries")
}

model VariableReward {
  id        String   @id @default(cuid())
  userId    String
  type      String   // surprise_bonus, spotlight, badge_upgrade, streak_save
  title     String
  message   String
  points    Int      @default(0)
  metadata  Json?
  claimed   Boolean  @default(false)
  expiresAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId, claimed])
  @@map("variable_rewards")
}

// ─── GI Configuration ───────────────────────────────────

model GIConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedBy   String
  updatedAt   DateTime @updatedAt

  @@map("gi_configs")
}

model GITierAssignment {
  id         String   @id @default(cuid())
  actionType String   @unique
  tier       Int
  updatedBy  String
  updatedAt  DateTime @updatedAt

  @@map("gi_tier_assignments")
}

// ─── Relay: Content Distribution ────────────────────────

enum PostStatus {
  DRAFT
  QUEUED
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}

model ContentPost {
  id             String     @id @default(cuid())
  title          String
  content        String?    @db.Text
  platform       String     // youtube, x, instagram, linkedin, facebook
  brandId        String
  brand          Brand      @relation(fields: [brandId], references: [id])
  status         PostStatus @default(DRAFT)
  scheduledAt    DateTime?
  publishedAt    DateTime?
  publishedUrl   String?
  platformPostId String?    // ID from the platform after publishing
  mediaUrls      Json?      // array of media URLs
  metadata       Json?      // platform-specific data (hashtags, thumbnails, etc.)
  taskId         String?    // link to originating PMS task
  createdById    String
  errorMessage   String?
  analytics      PostAnalytics?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([brandId, platform])
  @@index([status, scheduledAt])
  @@index([platform, status])
  @@map("content_posts")
}

model PostAnalytics {
  id             String      @id @default(cuid())
  post           ContentPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId         String      @unique
  views          Int         @default(0)
  likes          Int         @default(0)
  comments       Int         @default(0)
  shares         Int         @default(0)
  clicks         Int         @default(0)
  reach          Int         @default(0)
  impressions    Int         @default(0)
  engagementRate Float       @default(0)
  rawData        Json?       // full platform analytics response
  lastSyncedAt   DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@map("post_analytics")
}

model PlatformConnection {
  id             String   @id @default(cuid())
  brandId        String
  brand          Brand    @relation(fields: [brandId], references: [id])
  platform       String   // youtube, x, instagram, linkedin, facebook
  accessToken    String?  @db.Text
  refreshToken   String?  @db.Text
  accountId      String?  // platform account/page ID
  accountName    String?
  tokenExpiresAt DateTime?
  isActive       Boolean  @default(true)
  config         Json?    // platform-specific config
  connectedAt    DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([brandId, platform])
  @@map("platform_connections")
}

model ContentCalendarEntry {
  id            String   @id @default(cuid())
  title         String
  description   String?
  brandId       String
  platform      String
  deliverableType String // video, carousel, reel, thread, post, story
  date          DateTime
  assigneeId    String?
  status        String   @default("planned") // planned, in_progress, ready, posted
  postId        String?  // links to ContentPost when created
  metadata      Json?
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([brandId, date])
  @@index([date])
  @@map("content_calendar")
}

// ─── Communication ──────────────────────────────────────

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Announcement {
  id           String               @id @default(cuid())
  title        String
  content      String               @db.Text
  type         String               @default("general") // general, urgent, policy, celebration
  priority     AnnouncementPriority @default(NORMAL)
  scope        String               @default("org") // org, department, brand
  scopeId      String?              // departmentId or brandId if scoped
  authorId     String
  departmentId String?              // null = org-wide
  isPinned     Boolean              @default(false)
  expiresAt    DateTime?
  readBy       AnnouncementRead[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([departmentId, createdAt])
  @@index([scope, scopeId])
  @@map("announcements")
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  announcementId String
  userId         String
  readAt         DateTime     @default(now())

  @@unique([announcementId, userId])
  @@map("announcement_reads")
}

model FeedbackChannel {
  id          String           @id @default(cuid())
  name        String
  description String?
  type        String           @default("suggestion") // suggestion, concern, idea, general
  isAnonymous Boolean          @default(true)
  isActive    Boolean          @default(true)
  entries     FeedbackEntry[]
  createdAt   DateTime         @default(now())

  @@map("feedback_channels")
}

model FeedbackEntry {
  id        String          @id @default(cuid())
  channel   FeedbackChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  channelId String
  userId    String?         // null if anonymous
  content   String          @db.Text
  status    String          @default("open") // open, acknowledged, in_progress, resolved, closed
  response  String?         @db.Text
  respondedBy String?
  respondedAt DateTime?
  upvotes   Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([channelId, status])
  @@map("feedback_entries")
}
