generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  HEAD_HR
  DEPT_HEAD
  MEMBER
  CLIENT
  FINANCE
  CONTRACTOR
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum DepartmentType {
  MEDIA
  TECH
  MARKETING
  PRODUCTION
  PPC
  PHOTOGRAPHY
  HR_OPS
  FINANCE_DEPT
  CUSTOM
}

// ─── Core Models ─────────────────────────────────────────

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  name                String
  avatar              String?
  role                Role                @default(MEMBER)
  isActive            Boolean             @default(false)
  primaryDepartment   Department?         @relation("PrimaryDept", fields: [primaryDeptId], references: [id])
  primaryDeptId       String?
  departments         DepartmentMember[]
  brandAccess         UserBrandAccess[]
  permissionOverrides UserPermission[]
  projectTags         ProjectMember[]
  sidebarPreference   SidebarPreference?
  client              Client?
  accounts            Account[]
  sessions            Session[]
  // PMS relations
  createdTasks        Task[]              @relation("TaskCreator")
  assignedTasks       Task[]              @relation("TaskAssignee")
  taskComments        TaskComment[]       @relation("CommentAuthor")
  taskActivities      TaskActivity[]      @relation("ActivityActor")
  credibilityScore    CredibilityScore?
  // HOCCR relations
  createdReports      Report[]            @relation("ReportCreator")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Department ──────────────────────────────────────────

model Department {
  id           String             @id @default(cuid())
  name         String             @unique
  type         DepartmentType
  description  String?
  config       Json?
  headId       String?
  members      DepartmentMember[]
  primaryUsers User[]             @relation("PrimaryDept")
  projects     Project[]
  tasks        Task[]             @relation("DeptTasks")
  positions    HiringPosition[]   @relation("DeptPositions")
  reports      Report[]           @relation("DeptReports")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@map("departments")
}

model DepartmentMember {
  id           String     @id @default(cuid())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId String
  isPrimary    Boolean    @default(false)
  joinedAt     DateTime   @default(now())

  @@unique([userId, departmentId])
  @@map("department_members")
}

// ─── Client & Brand ──────────────────────────────────────

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  company   String?
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])
  brands    Brand[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

model Brand {
  id         String            @id @default(cuid())
  name       String
  slug       String            @unique
  client     Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId   String
  config     Json?
  platforms  BrandPlatform[]
  userAccess UserBrandAccess[]
  tasks      Task[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@map("brands")
}

model UserBrandAccess {
  id      String  @id @default(cuid())
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  brand   Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId String
  role    String?

  @@unique([userId, brandId])
  @@map("user_brand_access")
}

model BrandPlatform {
  id       String  @id @default(cuid())
  brand    Brand   @relation(fields: [brandId], references: [id], onDelete: Cascade)
  brandId  String
  platform String
  config   Json?
  isActive Boolean @default(true)

  @@unique([brandId, platform])
  @@map("brand_platforms")
}

// ─── Projects ────────────────────────────────────────────

model Project {
  id          String          @id @default(cuid())
  name        String
  description String?
  department  Department      @relation(fields: [deptId], references: [id])
  deptId      String
  members     ProjectMember[]
  tasks       Task[]
  status      String          @default("active")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("projects")
}

model ProjectMember {
  id        String  @id @default(cuid())
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      String?

  @@unique([projectId, userId])
  @@map("project_members")
}

// ─── Permissions ─────────────────────────────────────────

model UserPermission {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  permission String
  granted    Boolean  @default(true)
  grantedBy  String
  createdAt  DateTime @default(now())

  @@map("user_permissions")
}

// ─── Sidebar ─────────────────────────────────────────────

model SidebarPreference {
  id        String @id @default(cuid())
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String @unique
  pinned    Json   @default("[]")
  collapsed Json   @default("[]")
  order     Json   @default("[]")

  @@map("sidebar_preferences")
}

// ─── Module Registry ─────────────────────────────────────

model Module {
  id          String  @id @default(cuid())
  name        String  @unique
  displayName String
  description String?
  icon        String?
  baseUrl     String
  isActive    Boolean @default(true)
  config      Json?
  order       Int     @default(0)

  @@map("modules")
}

// ─── PMS: Tasks ─────────────────────────────────────────

enum TaskStatus {
  CREATED
  ASSIGNED
  IN_PROGRESS
  REVIEW
  APPROVED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id            String       @id @default(cuid())
  title         String
  description   String?      @db.Text
  status        TaskStatus   @default(CREATED)
  priority      TaskPriority @default(MEDIUM)
  difficultyWeight Int       @default(1)

  // Relations
  creator       User         @relation("TaskCreator", fields: [creatorId], references: [id])
  creatorId     String
  assignee      User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  assigneeId    String?
  department    Department?  @relation("DeptTasks", fields: [departmentId], references: [id])
  departmentId  String?
  brand         Brand?       @relation(fields: [brandId], references: [id])
  brandId       String?
  project       Project?     @relation(fields: [projectId], references: [id])
  projectId     String?

  // Dates
  dueDate       DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Sub-relations
  comments      TaskComment[]
  activities    TaskActivity[]
  tags          TaskTag[]

  @@index([assigneeId, status])
  @@index([departmentId, status])
  @@index([status])
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  author    User     @relation("CommentAuthor", fields: [authorId], references: [id])
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("task_comments")
}

model TaskActivity {
  id        String   @id @default(cuid())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  actor     User     @relation("ActivityActor", fields: [actorId], references: [id])
  actorId   String
  action    String
  field     String?
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  @@map("task_activities")
}

model TaskTag {
  id     String @id @default(cuid())
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String
  name   String

  @@unique([taskId, name])
  @@map("task_tags")
}

// ─── PMS: Credibility Scoring ───────────────────────────

model CredibilityScore {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String   @unique
  reliability    Float    @default(50)
  quality        Float    @default(50)
  consistency    Float    @default(50)
  overallScore   Float    @default(50)
  tasksCompleted Int      @default(0)
  tasksOnTime    Int      @default(0)
  tasksLate      Int      @default(0)
  updatedAt      DateTime @updatedAt

  @@map("credibility_scores")
}

// ─── HOCCR: Hiring Pipeline ─────────────────────────────

enum CandidateStatus {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

model HiringPosition {
  id           String      @id @default(cuid())
  title        String
  department   Department  @relation("DeptPositions", fields: [departmentId], references: [id])
  departmentId String
  description  String?     @db.Text
  requirements Json?
  isOpen       Boolean     @default(true)
  candidates   HiringCandidate[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@map("hiring_positions")
}

model HiringCandidate {
  id           String          @id @default(cuid())
  name         String
  email        String
  phone        String?
  resumeUrl    String?
  status       CandidateStatus @default(APPLIED)
  position     HiringPosition  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  positionId   String
  notes        String?         @db.Text
  rating       Int?
  interviewDate DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@map("hiring_candidates")
}

// ─── HOCCR: Reports ─────────────────────────────────────

enum ReportType {
  DEPARTMENT_PERFORMANCE
  TEAM_WORKLOAD
  TASK_COMPLETION
  HIRING_PIPELINE
  CUSTOM
}

model Report {
  id           String     @id @default(cuid())
  title        String
  type         ReportType
  description  String?
  config       Json?
  generatedData Json?
  createdBy    User       @relation("ReportCreator", fields: [createdById], references: [id])
  createdById  String
  department   Department? @relation("DeptReports", fields: [departmentId], references: [id])
  departmentId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("reports")
}

// ─── GI Configuration ───────────────────────────────────

model GIConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedBy   String
  updatedAt   DateTime @updatedAt

  @@map("gi_configs")
}

model GITierAssignment {
  id         String   @id @default(cuid())
  actionType String   @unique
  tier       Int
  updatedBy  String
  updatedAt  DateTime @updatedAt

  @@map("gi_tier_assignments")
}
